PORT=8092

# Same Supabase DATABASE_URL as integration-service (device_tokens table).
DATABASE_URL=postgresql://sharingbridge:sharingbridge@localhost:5432/sharingbridge

# Must match integration-service CONNECTION_NOTIFY_WEBHOOK_SECRET.
WEBHOOK_SECRET=change-me-shared-with-integration-service

# Firebase Admin — path to service account JSON from Firebase console.
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-adminsdk.json
# Or inline JSON for Render secret file:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

LOG_LEVEL=warn
